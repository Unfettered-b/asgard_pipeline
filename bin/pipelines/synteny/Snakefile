from datetime import datetime
import os
import shutil
import sys
import glob

# Expect config from CLI
if not config:
    raise ValueError("No config provided. Use --configfile.")

PROTEIN = config["protein_name"]

TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")
RUN_ID = config.get("run_id", TIMESTAMP)

BASE_DIR = os.getcwd()
CURRENT_DIR = config.get('base_dir', workflow.basedir)
RESULT_DIR = config.get("parent_dir", f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{RUN_ID}")
SYNTENY_DIR = f"{RESULT_DIR}/synteny"


# Create directories
os.makedirs(RESULT_DIR, exist_ok=True)
os.makedirs(SYNTENY_DIR, exist_ok=True)


# Include rule definitions





FINAL_TARGETS = [
    f"{RESULT_DIR}/synteny_pipeline.log"
]



rule all:
    input:
        FINAL_TARGETS


rule link_log_file:
    output:
        f"{RESULT_DIR}/synteny_pipeline.log"
    params:
        logfile = LOG
    shell:
        "ln -sf {params.logfile} {output}"


if config.get("from_existing_folder", False):
    include: "rules/from_existing_folder.smk"


