########################################
# Main Snakefile
########################################

from datetime import datetime
import os
import shutil
import sys
import glob

# Expect config from CLI
if not config:
    raise ValueError("No config provided. Use --configfile.")

PROTEIN = config["protein_name"]

TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")
RUN_ID = config.get("run_id", TIMESTAMP)

BASE_DIR = os.getcwd()
CURRENT_DIR = config.get('base_dir', workflow.basedir)
RESULT_DIR = f"{BASE_DIR}/database/protein_sets/{PROTEIN}/{RUN_ID}"
EXPLORATION_DIR = f"{RESULT_DIR}/extraction_exploration"
PHYLO_DIR = f"{RESULT_DIR}/final_phylogeny"

# Create directories
os.makedirs(RESULT_DIR, exist_ok=True)
os.makedirs(EXPLORATION_DIR, exist_ok=True)
os.makedirs(PHYLO_DIR, exist_ok = True)

# Include rule definitions

if config.get("parse_ips", False):
    include: "rules/parse_ips.smk"
elif config.get("hmmsearch", False):
    include: "rules/hmmsearch.smk" # yet to be done
elif config.get("from_manual", False):
    include: "rules/from_manual.smk" # yet to be done
else:
    print("Must include atleast one mode of id extraction")
    sys.exit()

include: "rules/exploration.smk"

########################################
# Final Target
########################################
FINAL_TARGETS = [
    f"{RESULT_DIR}/REVIEW_DONE.flag",
    f"{PHYLO_DIR}/{PROTEIN}_phylo.treefile",
]

# optional iTOL upload
if config.get("run_itol_upload", False):
    FINAL_TARGETS.append(f"{RESULT_DIR}/{PROTEIN}_main_itol_uploaded.flag")

# add plots
FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/protein_length_vs_{{level}}.png",
        level=config.get("PLOT_TAXON_LEVELS")
    )
)

FINAL_TARGETS.extend(
    expand(
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/copy_heatmap_{{level}}.png",
        level=config.get("PLOT_TAXON_LEVELS")
    )
)

rule all:
    input:
        FINAL_TARGETS


############################################
# taxa plotting from unr.csv
############################################


rule protein_copy_heatmap:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"

    output:
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/copy_heatmap_{{level}}.png"

    params:
        proteins = config.get("PLOT_PROTEINS_PRESENCE", ["FtsZ1","FtsZ2","CetZ","Tubulin"])

    wildcard_constraints:
        level="|".join(config.get("PLOT_TAXON_LEVELS", ["class"]))
    
    conda: 
        f"{config['env_dir']}/bio-r.yaml"

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/bubble_heat_map_presence_table.r \
        {input.csv} \
        {wildcards.level} \
        genome_file \
        Manual_annotation \
        {output} \
        --proteins {params.proteins:q}
        """



rule plot_taxa:
    input:
        csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"

    output:
        f"{EXPLORATION_DIR}/plots/{PROTEIN}/protein_length_vs_{{level}}.png"

    params:
        y = config.get("PLOT_Y_COLUMN","protein_length"),
        filter_col = config.get("PLOT_FILTER_COLUMN", "Manual_annotation"),
        filter_vals = config.get("PLOT_FILTER_VALS", ['FtsZ1','FtsZ2','CetZ','Tubulin']),
        dual_vals = config.get("PLOT_DUAL_PROTEINS", ['FtsZ1','FtsZ2']),
        dual_arg = lambda wildcards: (
            "--dual " + " ".join(config.get("PLOT_DUAL_PROTEINS", []))
            if config.get("PLOT_DUAL_PROTEINS", [])
            else ""
        )
    
    conda: 
        f"{config['env_dir']}/bio-r.yaml"


    wildcard_constraints:
        level="|".join(config.get("PLOT_TAXON_LEVELS", ["class"]))

    shell:
        """
        Rscript {CURRENT_DIR}/bin/units/taxon_violin_plot.r \
        {input.csv} \
        {params.y} \
        {wildcards.level} \
        {output} \
        --filter {params.filter_col} {params.filter_vals:q} \
        {params.dual_arg}
        """


############################################
# Final Phylogeny (after manual review)
############################################

rule run_phylogeny:
    input:
        flag = f"{RESULT_DIR}/REVIEW_DONE.flag", 
        fasta = f"{RESULT_DIR}/{PROTEIN}.rev.fasta"
    output:
        tree = f"{PHYLO_DIR}/{PROTEIN}_phylo.treefile"
    threads: config.get("phylogeny_threads", 8)
    conda:
        f"{config['env_dir']}/phylogeny.yaml"
    params:
        prefix = f"{PHYLO_DIR}/{PROTEIN}_phylo"
    message:
        """
        ==========================================
        🌳 Running Final Phylogeny
        Input: {input.fasta}
        Prefix: {params.prefix}
        Threads: {threads}
        ==========================================
        """
    shell:
        """
        bash bin/units/phylogeny_pipeline.sh \
            {input.fasta} \
            {params.prefix} \
            {threads}
        """

rule df_for_annotation:
    input: 
        fasta = f"{RESULT_DIR}/{PROTEIN}.rev.fasta", 
        protein_csv = f"{EXPLORATION_DIR}/{PROTEIN}.unr.csv"
    output:
        annot_csv = f"{PHYLO_DIR}/{PROTEIN}.annot.csv"
    conda:
        f"{config['env_dir']}/Reg.yaml"
    shell:
        """
        python {CURRENT_DIR}/bin/units/get_annotation_csv.py \
                {input.fasta} \
                {input.protein_csv} \
                {output.annot_csv}        
        
        """

rule table2itol:
    input:
        annot = f"{PHYLO_DIR}/{PROTEIN}.annot.csv"
    output:
        annotation_dir = directory(f"{PHYLO_DIR}/annotation"),    
        done_annot = touch(f"{PHYLO_DIR}/annotation.done.flag")
    conda:
        f"{config['env_dir']}/bio-r.yaml"
    shell:
        """
        mkdir -p {output.annotation_dir}

        Rscript {CURRENT_DIR}/bin/units/table2itol.R \
            -i locus_tag \
            -l locus_tag \
            -s "," \
            -D {output.annotation_dir} \
            {input.annot}
        """


rule upload_main_tree_to_itol:
    input:
        tree = f"{PHYLO_DIR}/{PROTEIN}_phylo.treefile",
        done_annot = f"{PHYLO_DIR}/annotation.done.flag",
        colorstrip = f"{RESULT_DIR}/extraction_exploration/{PROTEIN}_colorstrip.txt",
        default = lambda wildcards: config.get("default_annotation", ""),
        annotation_files = lambda wildcards: sorted(
            glob.glob(f"{PHYLO_DIR}/annotation/*.txt")
        )
    output:
        tree_ids = f"{RESULT_DIR}/{PROTEIN}_main_itol_uploaded.flag"
    params:
        project = config.get("itol_project", "Asgard"),
        tree_name = f"mafft_{config.get('run_id', 'run')}_{PROTEIN}"
    shell:
        """
        bash {CURRENT_DIR}/bin/units/itol_upload.sh \
            {input.tree} \
            {params.project} \
            {params.tree_name} \
            {output.tree_ids} \
            {input.colorstrip} \
            {input.default} \
            {input.annotation_files:q}
        """